generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Concesionaria {
  id                      Int                        @id @default(autoincrement())
  nombre                  String
  cuit                    String?
  email                   String?
  telefono                String?
  direccion               String?
  createdAt               DateTime                   @default(now()) @map("created_at")
  updatedAt               DateTime                   @updatedAt @map("updated_at")
  deletedAt               DateTime?                  @map("deleted_at")
  auditLogs               AuditLog[]
  categoriasGastoFijo     CategoriaGastoFijo[]
  categoriasGastoVehiculo CategoriaGastoVehiculo[]
  clientes                Cliente[]
  subscription            ConcesionariaSubscription?
  financiaciones          Financiacion[]
  financieras             Financiera[]
  gastosFijos             GastoFijo[]
  gastosVehiculo          GastoVehiculo[]
  ingresosVehiculo        IngresoVehiculo[]
  marcas                  Marca[]
  modelos                 Modelo[]
  postventaCasos          PostventaCaso[]
  presupuestos            Presupuesto[]
  proveedores             Proveedor[]
  reservas                Reserva[]
  solicitudesFinanciacion SolicitudFinanciacion[]
  sucursales              Sucursal[]
  usuarios                Usuario[]
  vehiculoMovimientos     VehiculoMovimiento[]
  vehiculos               Vehiculo[]
  ventas                  Venta[]
  versiones               VersionVehiculo[]
  cajas                   Caja[]
  cierresCaja             CierreCaja[]
  movimientosCaja         MovimientoCaja[]

  @@map("concesionarias")
}

model Sucursal {
  id                       Int                     @id @default(autoincrement())
  concesionariaId          Int                     @map("concesionaria_id")
  nombre                   String
  direccion                String?
  ciudad                   String?
  email                    String?
  telefono                 String?
  activo                   Boolean                 @default(true)
  createdAt                DateTime                @default(now()) @map("created_at")
  updatedAt                DateTime                @updatedAt @map("updated_at")
  deletedAt                DateTime?               @map("deleted_at")
  financiaciones           Financiacion[]
  gastosFijos              GastoFijo[]
  ingresosVehiculo         IngresoVehiculo[]
  postventaCasos           PostventaCaso[]
  presupuestos             Presupuesto[]
  reservas                 Reserva[]
  solicitudesFinanciacion  SolicitudFinanciacion[]
  concesionaria            Concesionaria           @relation(fields: [concesionariaId], references: [id])
  usuarios                 Usuario[]
  vehiculoMovimientosDesde VehiculoMovimiento[]    @relation("MovDesdeSucursal")
  vehiculoMovimientosHasta VehiculoMovimiento[]    @relation("MovHastaSucursal")
  vehiculos                Vehiculo[]
  ventas                   Venta[]

  @@unique([concesionariaId, nombre])
  @@index([concesionariaId])
  @@map("sucursales")
}

model Rol {
  id           Int          @id @default(autoincrement())
  nombre       RolNombre    @unique
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")
  usuarioRoles UsuarioRol[]

  @@map("roles")
}

enum EstadoUsuario {
  pendiente
  activo
  bloqueado
}

enum AccountTokenType {
  activacion
  reset
}

model Usuario {
  id                     Int                  @id @default(autoincrement())
  concesionariaId        Int?                 @map("concesionaria_id")
  sucursalId             Int?                 @map("sucursal_id")
  nombre                 String
  email                  String
  passwordHash           String?              @map("password_hash")
  activo                 Boolean              @default(true)
  emailVerificado        Boolean              @default(false) @map("email_verificado")
  estado                 EstadoUsuario        @default(pendiente)
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")
  deletedAt              DateTime?            @map("deleted_at")
  accountTokens          AccountToken[]
  auditLogs              AuditLog[]
  financiacionesCobrador Financiacion[]       @relation("FinanciacionCobrador")
  ingresosVehiculo       IngresoVehiculo[]    @relation("IngresoRegistradoPor")
  presupuestos           Presupuesto[]        @relation("PresupuestoVendedor")
  reservasCreadas        Reserva[]            @relation("ReservaCreadaPor")
  roles                  UsuarioRol[]
  concesionaria          Concesionaria?       @relation(fields: [concesionariaId], references: [id])
  sucursal               Sucursal?            @relation(fields: [sucursalId], references: [id])
  vehiculoMovimientos    VehiculoMovimiento[] @relation("MovimientoRegistradoPor")
  ventas                 Venta[]              @relation("VentaVendedor")
  refreshTokens          RefreshToken[]

  @@unique([concesionariaId, email])
  @@index([concesionariaId])
  @@index([email])
  @@index([estado])
  @@map("usuarios")
}

model UsuarioRol {
  id        Int       @id @default(autoincrement())
  usuarioId Int       @map("usuario_id")
  rolId     Int       @map("rol_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  rol       Rol       @relation(fields: [rolId], references: [id])
  usuario   Usuario   @relation(fields: [usuarioId], references: [id])

  @@unique([usuarioId, rolId])
  @@map("usuario_roles")
}

model Cliente {
  id                      Int                     @id @default(autoincrement())
  concesionariaId         Int                     @map("concesionaria_id")
  nombre                  String
  dni                     String?
  telefono                String?
  email                   String?
  direccion               String?
  observaciones           String?
  createdAt               DateTime                @default(now()) @map("created_at")
  updatedAt               DateTime                @updatedAt @map("updated_at")
  deletedAt               DateTime?               @map("deleted_at")
  concesionaria           Concesionaria           @relation(fields: [concesionariaId], references: [id])
  financiaciones          Financiacion[]
  ingresosVehiculo        IngresoVehiculo[]
  postventaCasos          PostventaCaso[]
  presupuestos            Presupuesto[]
  reservas                Reserva[]
  solicitudesFinanciacion SolicitudFinanciacion[]
  ventas                  Venta[]

  @@index([concesionariaId])
  @@index([dni])
  @@index([telefono])
  @@map("clientes")
}

model Proveedor {
  id              Int               @id @default(autoincrement())
  concesionariaId Int               @map("concesionaria_id")
  nombre          String
  tipo            String?
  telefono        String?
  email           String?
  direccion       String?
  activo          Boolean           @default(true)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")
  gastosFijos     GastoFijo[]
  gastosVehiculo  GastoVehiculo[]
  ingresosOrigen  IngresoVehiculo[] @relation("IngresoProveedorOrigen")
  postventaItems  PostventaItem[]
  concesionaria   Concesionaria     @relation(fields: [concesionariaId], references: [id])
  vehiculosCompra Vehiculo[]        @relation("VehiculoProveedorCompra")

  @@index([concesionariaId])
  @@index([tipo])
  @@map("proveedores")
}

model Marca {
  id              Int           @id @default(autoincrement())
  concesionariaId Int           @map("concesionaria_id")
  nombre          String
  activo          Boolean       @default(true)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")
  concesionaria   Concesionaria @relation(fields: [concesionariaId], references: [id])
  modelos         Modelo[]
  vehiculos       Vehiculo[]    @relation("VehiculoMarcaCatalogo")

  @@unique([concesionariaId, nombre])
  @@index([concesionariaId])
  @@map("marcas")
}

model Modelo {
  id              Int               @id @default(autoincrement())
  concesionariaId Int               @map("concesionaria_id")
  marcaId         Int               @map("marca_id")
  nombre          String
  activo          Boolean           @default(true)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")
  concesionaria   Concesionaria     @relation(fields: [concesionariaId], references: [id])
  marca           Marca             @relation(fields: [marcaId], references: [id])
  versiones       VersionVehiculo[]
  vehiculos       Vehiculo[]        @relation("VehiculoModeloCatalogo")

  @@unique([marcaId, nombre])
  @@index([concesionariaId])
  @@index([marcaId])
  @@map("modelos")
}

model VersionVehiculo {
  id              Int           @id @default(autoincrement())
  concesionariaId Int           @map("concesionaria_id")
  modeloId        Int           @map("modelo_id")
  nombre          String
  anio            Int?
  precioSugerido  Decimal?      @map("precio_sugerido") @db.Decimal(12, 2)
  activo          Boolean       @default(true)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")
  concesionaria   Concesionaria @relation(fields: [concesionariaId], references: [id])
  modelo          Modelo        @relation(fields: [modeloId], references: [id])
  vehiculos       Vehiculo[]    @relation("VehiculoVersionCatalogo")

  @@unique([modeloId, nombre, anio])
  @@index([concesionariaId])
  @@index([modeloId])
  @@map("versiones_vehiculo")
}

/// Caja física o virtual de la concesionaria. Cada concesionaria arranca con
/// "Caja Efectivo" + "Caja MP" pero puede crear más (cuentas bancarias,
/// dólares, etc.). Tiene movimientos sumados (saldo actual) y cierres diarios
/// que registran saldo real (lo que efectivamente hay) vs saldo teórico.
model Caja {
  id              Int              @id @default(autoincrement())
  concesionariaId Int              @map("concesionaria_id")
  nombre          String
  tipo            CajaTipo
  moneda          String           @default("ARS")
  activo          Boolean          @default(true)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")
  concesionaria   Concesionaria    @relation(fields: [concesionariaId], references: [id])
  cierres         CierreCaja[]
  movimientos     MovimientoCaja[]

  @@unique([concesionariaId, nombre])
  @@index([concesionariaId])
  @@map("cajas")
}

/// Movimiento individual de caja: ingreso o egreso, manual o disparado por
/// otra entidad (venta, gasto). Sumando movimientos se obtiene el saldo
/// teórico actual.
model MovimientoCaja {
  id              Int              @id @default(autoincrement())
  concesionariaId Int              @map("concesionaria_id")
  cajaId          Int              @map("caja_id")
  tipo            MovimientoTipo
  fecha           DateTime         @db.Date
  monto           Decimal          @db.Decimal(14, 2)
  descripcion     String?
  origen          MovimientoOrigen @default(manual)
  // Referencia opcional a la entidad que disparó el movimiento (venta/gasto).
  entidadOrigen   String?          @map("entidad_origen")
  entidadOrigenId Int?             @map("entidad_origen_id")
  registradoPorId Int?             @map("registrado_por_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")
  caja            Caja             @relation(fields: [cajaId], references: [id])
  concesionaria   Concesionaria    @relation(fields: [concesionariaId], references: [id])

  @@index([concesionariaId])
  @@index([cajaId, fecha])
  @@index([entidadOrigen, entidadOrigenId])
  @@map("movimientos_caja")
}

/// Cierre diario de caja: saldo inicial (heredado del día anterior), total
/// de ingresos y egresos del día, saldo teórico (calculado), saldo real
/// (lo que efectivamente hay físico/contado en MP) y diferencia. Sirve de
/// auditoría diaria.
model CierreCaja {
  id              Int           @id @default(autoincrement())
  concesionariaId Int           @map("concesionaria_id")
  cajaId          Int           @map("caja_id")
  fecha           DateTime      @db.Date
  saldoInicial    Decimal       @default(0) @map("saldo_inicial") @db.Decimal(14, 2)
  ingresosDia     Decimal       @default(0) @map("ingresos_dia") @db.Decimal(14, 2)
  egresosDia      Decimal       @default(0) @map("egresos_dia") @db.Decimal(14, 2)
  saldoTeorico    Decimal       @default(0) @map("saldo_teorico") @db.Decimal(14, 2)
  saldoReal       Decimal?      @map("saldo_real") @db.Decimal(14, 2)
  diferencia      Decimal?      @db.Decimal(14, 2)
  observaciones   String?
  cerradoPorId    Int?          @map("cerrado_por_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")
  caja            Caja          @relation(fields: [cajaId], references: [id])
  concesionaria   Concesionaria @relation(fields: [concesionariaId], references: [id])

  @@unique([cajaId, fecha])
  @@index([concesionariaId])
  @@index([cajaId, fecha])
  @@map("cierres_caja")
}

model Vehiculo {
  id                       Int                  @id @default(autoincrement())
  concesionariaId          Int                  @map("concesionaria_id")
  sucursalId               Int                  @map("sucursal_id")
  tipo                     TipoVehiculo         @default(USADO)
  origen                   OrigenVehiculo       @default(compra)
  marca                    String
  modelo                   String
  version                  String?
  marcaId                  Int?                 @map("marca_id")
  modeloId                 Int?                 @map("modelo_id")
  versionVehiculoId        Int?                 @map("version_vehiculo_id")
  anio                     Int?
  dominio                  String?
  vin                      String?
  kmIngreso                Int?                 @map("km_ingreso")
  color                    String?
  estado                   EstadoVehiculo       @default(preparacion)
  fechaIngreso             DateTime             @map("fecha_ingreso") @db.Date
  fechaCompra              DateTime?            @map("fecha_compra") @db.Date
  precioCompra             Decimal?             @map("precio_compra") @db.Decimal(12, 2)
  precioLista              Decimal?             @map("precio_lista") @db.Decimal(12, 2)
  proveedorCompraId        Int?                 @map("proveedor_compra_id")
  formaPagoCompra          String?              @map("forma_pago_compra")
  observaciones            String?
  createdAt                DateTime             @default(now()) @map("created_at")
  updatedAt                DateTime             @updatedAt @map("updated_at")
  deletedAt                DateTime?            @map("deleted_at")
  gastos                   GastoVehiculo[]
  ingresos                 IngresoVehiculo[]
  postventaCasos           PostventaCaso[]      @relation("CasoVehiculo")
  presupuestoCanjeGenerado PresupuestoCanje[]   @relation("VehiculoGeneradoDesdeCanje")
  presupuestoItems         PresupuestoItem[]
  reservas                 Reserva[]
  archivos                 VehiculoArchivo[]
  movimientos              VehiculoMovimiento[]
  concesionaria            Concesionaria        @relation(fields: [concesionariaId], references: [id])
  proveedorCompra          Proveedor?           @relation("VehiculoProveedorCompra", fields: [proveedorCompraId], references: [id])
  sucursal                 Sucursal             @relation(fields: [sucursalId], references: [id])
  marcaCatalogo            Marca?               @relation("VehiculoMarcaCatalogo", fields: [marcaId], references: [id])
  modeloCatalogo           Modelo?              @relation("VehiculoModeloCatalogo", fields: [modeloId], references: [id])
  versionCatalogo          VersionVehiculo?     @relation("VehiculoVersionCatalogo", fields: [versionVehiculoId], references: [id])
  ventaCanjeVehiculo       VentaCanjeVehiculo[]
  ventas                   Venta?

  @@unique([concesionariaId, vin])
  @@index([concesionariaId])
  @@index([sucursalId])
  @@index([dominio])
  @@index([vin])
  @@index([estado])
  @@index([marcaId])
  @@index([modeloId])
  @@index([versionVehiculoId])
  @@map("vehiculos")
}

model VehiculoArchivo {
  id              Int       @id @default(autoincrement())
  concesionariaId Int?      @map("concesionaria_id")
  vehiculoId      Int       @map("vehiculo_id")
  tipo            String?
  url             String
  descripcion     String?
  originalName    String?   @map("original_name")
  mimeType        String?   @map("mime_type")
  sizeBytes       Int?      @map("size_bytes")
  storageKey      String?   @map("storage_key")
  uploadedById    Int?      @map("uploaded_by_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  vehiculo        Vehiculo  @relation(fields: [vehiculoId], references: [id])

  @@index([concesionariaId])
  @@index([vehiculoId])
  @@map("vehiculo_archivos")
}

model IngresoVehiculo {
  id                Int                 @id @default(autoincrement())
  concesionariaId   Int                 @map("concesionaria_id")
  sucursalId        Int                 @map("sucursal_id")
  vehiculoId        Int                 @map("vehiculo_id")
  tipoIngreso       TipoIngresoVehiculo @map("tipo_ingreso")
  clienteOrigenId   Int?                @map("cliente_origen_id")
  proveedorOrigenId Int?                @map("proveedor_origen_id")
  presupuestoId     Int?                @map("presupuesto_id")
  ventaId           Int?                @map("venta_id")
  fechaIngreso      DateTime            @map("fecha_ingreso") @db.Date
  valorTomado       Decimal?            @map("valor_tomado") @db.Decimal(12, 2)
  observaciones     String?
  registradoPorId   Int?                @map("registrado_por_id")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  deletedAt         DateTime?           @map("deleted_at")
  clienteOrigen     Cliente?            @relation(fields: [clienteOrigenId], references: [id])
  concesionaria     Concesionaria       @relation(fields: [concesionariaId], references: [id])
  presupuesto       Presupuesto?        @relation(fields: [presupuestoId], references: [id])
  proveedorOrigen   Proveedor?          @relation("IngresoProveedorOrigen", fields: [proveedorOrigenId], references: [id])
  registradoPor     Usuario?            @relation("IngresoRegistradoPor", fields: [registradoPorId], references: [id])
  sucursal          Sucursal            @relation(fields: [sucursalId], references: [id])
  vehiculo          Vehiculo            @relation(fields: [vehiculoId], references: [id])
  venta             Venta?              @relation(fields: [ventaId], references: [id])

  @@index([concesionariaId])
  @@index([sucursalId])
  @@index([vehiculoId])
  @@map("ingresos_vehiculo")
}

model VehiculoMovimiento {
  id              Int                    @id @default(autoincrement())
  concesionariaId Int                    @map("concesionaria_id")
  vehiculoId      Int                    @map("vehiculo_id")
  desdeSucursalId Int?                   @map("desde_sucursal_id")
  hastaSucursalId Int?                   @map("hasta_sucursal_id")
  tipo            TipoMovimientoVehiculo
  fecha           DateTime               @default(now())
  motivo          String?
  registradoPorId Int?                   @map("registrado_por_id")
  createdAt       DateTime               @default(now()) @map("created_at")
  deletedAt       DateTime?              @map("deleted_at")
  concesionaria   Concesionaria          @relation(fields: [concesionariaId], references: [id])
  desdeSucursal   Sucursal?              @relation("MovDesdeSucursal", fields: [desdeSucursalId], references: [id])
  hastaSucursal   Sucursal?              @relation("MovHastaSucursal", fields: [hastaSucursalId], references: [id])
  registradoPor   Usuario?               @relation("MovimientoRegistradoPor", fields: [registradoPorId], references: [id])
  vehiculo        Vehiculo               @relation(fields: [vehiculoId], references: [id])

  @@index([concesionariaId])
  @@index([vehiculoId])
  @@index([desdeSucursalId])
  @@index([hastaSucursalId])
  @@map("vehiculo_movimientos")
}

model Reserva {
  id              Int           @id @default(autoincrement())
  concesionariaId Int           @map("concesionaria_id")
  sucursalId      Int           @map("sucursal_id")
  vehiculoId      Int           @map("vehiculo_id")
  clienteId       Int           @map("cliente_id")
  creadaPorId     Int?          @map("creada_por_id")
  estado          EstadoReserva @default(activa)
  fecha           DateTime      @db.Date
  venceEl         DateTime?     @map("vence_el") @db.Date
  montoSenia      Decimal?      @map("monto_senia") @db.Decimal(12, 2)
  metodo          MetodoPago?
  referencia      String?
  observaciones   String?
  ventaId         Int?          @map("venta_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")
  cliente         Cliente       @relation(fields: [clienteId], references: [id])
  concesionaria   Concesionaria @relation(fields: [concesionariaId], references: [id])
  creadaPor       Usuario?      @relation("ReservaCreadaPor", fields: [creadaPorId], references: [id])
  sucursal        Sucursal      @relation(fields: [sucursalId], references: [id])
  vehiculo        Vehiculo      @relation(fields: [vehiculoId], references: [id])
  venta           Venta?        @relation(fields: [ventaId], references: [id])

  @@index([concesionariaId])
  @@index([sucursalId])
  @@index([vehiculoId])
  @@index([clienteId])
  @@index([estado])
  @@map("reservas")
}

model CategoriaGastoVehiculo {
  id              Int             @id @default(autoincrement())
  concesionariaId Int             @map("concesionaria_id")
  nombre          String
  activo          Boolean         @default(true)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")
  concesionaria   Concesionaria   @relation(fields: [concesionariaId], references: [id])
  gastos          GastoVehiculo[]

  @@unique([concesionariaId, nombre])
  @@map("categorias_gasto_vehiculo")
}

model GastoVehiculo {
  id              Int                    @id @default(autoincrement())
  concesionariaId Int                    @map("concesionaria_id")
  vehiculoId      Int                    @map("vehiculo_id")
  categoriaId     Int                    @map("categoria_id")
  proveedorId     Int?                   @map("proveedor_id")
  fecha           DateTime               @db.Date
  monto           Decimal                @db.Decimal(12, 2)
  descripcion     String?
  comprobanteUrl  String?                @map("comprobante_url")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")
  deletedAt       DateTime?              @map("deleted_at")
  categoria       CategoriaGastoVehiculo @relation(fields: [categoriaId], references: [id])
  concesionaria   Concesionaria          @relation(fields: [concesionariaId], references: [id])
  proveedor       Proveedor?             @relation(fields: [proveedorId], references: [id])
  vehiculo        Vehiculo               @relation(fields: [vehiculoId], references: [id])

  @@index([concesionariaId])
  @@index([vehiculoId])
  @@index([fecha])
  @@index([categoriaId])
  @@map("gastos_vehiculo")
}

model CategoriaGastoFijo {
  id              Int           @id @default(autoincrement())
  concesionariaId Int           @map("concesionaria_id")
  nombre          String
