model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  usuarioId Int      @map("usuario_id")
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at")
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])

  @@map("refresh_tokens")
}

/// Tokens de activación de cuenta y reset de password.
/// El valor crudo (token) NO se guarda — solo su bcrypt-hash en `tokenHash`.
/// Cada token es single-use (se marca usedAt al consumirse).
/// `deletedAt` está por compatibilidad con el softDeleteExtension global,
/// que filtra por `deletedAt: null` en todas las reads.
model AccountToken {
  id        Int              @id @default(autoincrement())
  usuarioId Int              @map("usuario_id")
  tokenHash String           @map("token_hash")
  tipo      AccountTokenType
  expiresAt DateTime         @map("expires_at")
  usedAt    DateTime?        @map("used_at")
  createdAt DateTime         @default(now()) @map("created_at")
  deletedAt DateTime?        @map("deleted_at")
  usuario   Usuario          @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId, tipo])
  @@index([expiresAt])
  @@map("account_tokens")
}

/// Outbox de emails para SMTP con retries.
/// El service.send() persiste el email acá dentro de la transacción del
/// caller (ej: alta de usuario). Un worker async drainea los pendientes
/// con backoff exponencial. Si SMTP cae, los emails no se pierden.
model EmailOutbox {
  id           Int       @id @default(autoincrement())
  toAddress    String    @map("to_address")
  subject      String
  bodyText     String    @map("body_text") @db.Text
  bodyHtml     String    @map("body_html") @db.Text
  /// null = pendiente; fecha = enviado exitosamente
  sentAt       DateTime? @map("sent_at")
  attempts     Int       @default(0)
  lastError    String?   @map("last_error") @db.Text
  /// Próximo intento (con backoff). null si nunca fue intentado o ya se envió.
  nextAttemptAt DateTime? @map("next_attempt_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Index parcial-style: los que están pending y ready se queryean por (sent_at, next_attempt_at)
  @@index([sentAt, nextAttemptAt])
  @@map("email_outbox")
}
