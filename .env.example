# Server
NODE_ENV=development
PORT=3000

# Database (Postgres)
# Para Prisma adapter-pg, usar formato postgres:// estándar.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/concesionaria?sslmode=disable"

# Pool de conexiones por proceso (PM2 levanta varios — total = N × DB_POOL_MAX)
DB_POOL_MAX=5

# JWT — generar secrets random fuertes en producción (mínimo 32 chars)
# ej: openssl rand -base64 48
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
JWT_REFRESH_SECRET=replace_with_another_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — orígenes permitidos separados por coma
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost

# URL base del frontend (para los links de activación / reset por email)
APP_BASE_URL=http://localhost:5173

# Uploads
UPLOADS_DIR=./uploads

# Logging
LOG_LEVEL=info

# Seed (solo para desarrollo — en prod usar el flujo de invitación)
# Si se omiten, se usan defaults "changeme-*-DEV" (no usar en prod).
SEED_ADMIN_PASSWORD=changeme-admin-DEV
SEED_SUPER_PASSWORD=changeme-super-DEV

# Bootstrap automático del super_admin global del SaaS.
# Se ejecuta en cada arranque del container (idempotente: crea o actualiza).
# Si BOOTSTRAP_SUPER_PASSWORD NO se setea, el bootstrap solo crea roles + Plan
# Free y NO toca usuarios — ideal para deploys donde no querés un super_admin
# automático.
BOOTSTRAP_SUPER_EMAIL=soporteautenza@gmail.com
BOOTSTRAP_SUPER_PASSWORD=
BOOTSTRAP_SUPER_NAME=Soporte AUTENZA

# SMTP — si SMTP_HOST está seteado, se usa nodemailer; si no, los emails van al log.
#
# Proveedores recomendados (free tier):
#
# Brevo (300 emails/día gratis, sin tarjeta):
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_USER=tu-login@brevo.com    # del panel SMTP & API → SMTP
#   SMTP_PASS=xxxxxxxxxxxxxxxx       # SMTP key del mismo panel
#   SMTP_FROM=no-reply@tudominio.com
#
# Resend (3000 emails/mes gratis, dominio propio o resend.dev sandbox):
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_USER=resend
#   SMTP_PASS=re_xxxxxxxxxxxxxxxx    # API key de https://resend.com/api-keys
#   SMTP_FROM=no-reply@tudominio.com
#
# Gmail (500 emails/día, requiere App Password con 2FA activo):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=tu@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx    # App Password (NO tu password normal)
#   SMTP_FROM=tu@gmail.com
#
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=no-reply@autenza.local
